{
	"name": "notion-to-discord-bot",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"cf-typegen": "wrangler types",
		"check-types": "tsc --noEmit",
		"check:fix": "biome check --write",
		"check": "biome check",
		"deploy": "bun run build && wrangler deploy",
		"dev": "vite dev",
		"preview": "bun run build && vite preview",
		"start": "wrangler dev",
		"test": "vitest"
	},
	"cloudflare": {
		"bindings": {
			"DISCORD_BOT_TOKEN": {
				"description": "The token for the Discord bot"
			}
		}
	},
	"dependencies": {
		"hono": "^4.12.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@cloudflare/vite-plugin": "^1.28.0",
		"@cloudflare/vitest-pool-workers": "^0.13.1",
		"@notionhq/client": "^5.13.0",
		"discord-api-types": "^0.38.41",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.0",
		"wrangler": "^4.74.0"
	},
	"packageManager": "bun@1.3.6"
}
