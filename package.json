{
	"name": "notion-to-discord-bot",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"cf-typegen": "wrangler types",
		"check-types": "tsc --noEmit",
		"check:fix": "biome check --write",
		"check": "biome check",
		"deploy": "bun run build && wrangler deploy",
		"dev": "vite dev",
		"preview": "bun run build && vite preview",
		"start": "wrangler dev",
		"test": "vitest"
	},
	"cloudflare": {
		"bindings": {
			"DISCORD_BOT_TOKEN": {
				"description": "Discord Developer Portal: open your application → Bot → Reset Token."
			}
		}
	},
	"dependencies": {
		"hono": "^4.12.15"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@cloudflare/vite-plugin": "^1.33.2",
		"@cloudflare/vitest-pool-workers": "^0.15.0",
		"@notionhq/client": "^5.20.0",
		"discord-api-types": "^0.38.47",
		"typescript": "^5.9.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"wrangler": "^4.85.0"
	},
	"packageManager": "bun@1.3.6"
}
