{
	"name": "notion-to-discord-bot",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"cf-typegen": "wrangler types",
		"check-types": "tsc --noEmit",
		"check:fix": "biome check --write",
		"check": "biome check",
		"deploy": "bun run build && wrangler deploy",
		"dev": "vite dev",
		"preview": "bun run build && vite preview",
		"start": "wrangler dev",
		"test": "vitest"
	},
	"dependencies": {
		"hono": "^4.12.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@cloudflare/vite-plugin": "^1.26.1",
		"@cloudflare/vitest-pool-workers": "^0.12.20",
		"@notionhq/client": "^5.11.1",
		"discord-api-types": "^0.38.41",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitest": "2.1.9",
		"wrangler": "^4.71.0"
	},
	"packageManager": "bun@1.3.6"
}
